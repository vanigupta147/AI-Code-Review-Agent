# Backend (Python + Ollama): copy to backend/.env
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Seconds for Ollama to finish one review (large PR diffs often need 900+)
# Use 0 for no read timeout (unlimited wait for local Ollama)
OLLAMA_TIMEOUT=900
PORT=3001

# Optional: GitHub REST API (higher rate limits; required for private repos)
# GITHUB_TOKEN=ghp_...

# Frontend (optional): set in frontend .env to override API URL
# VITE_API_URL=http://localhost:3001
